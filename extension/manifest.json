{
  "manifest_version": 3,
  "name": "AgentCursor",
  "version": "0.2.0",
  "description": "Human-like cursor automation bridge for coding agents over MCP.",
  "permissions": ["tabs", "activeTab", "scripting", "debugger", "alarms"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
