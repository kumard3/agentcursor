{
  "name": "agentcursor",
  "version": "0.2.6",
  "description": "Local free human-like browser automation over MCP. Realistic cursor + interactions for coding agents, E2E testing, QA workflows, and general browser automation on real sites.",
  "type": "module",
  "bin": {
    "agentcursor": "dist/index.js"
  },
  "files": [
    "dist",
    "extension/dist",
    "extension/manifest.json",
    "extension/icons",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs && node extension/build.mjs",
    "build:server": "node build.mjs",
    "build:ext": "node extension/build.mjs",
    "reload": "AGENTCURSOR_BUMP=1 node extension/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node build.mjs && node scripts/smoke.mjs",
    "verify": "node scripts/verify-live.mjs",
    "demo": "node scripts/demo-drive.mjs",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "browser-automation",
    "human-cursor",
    "mouse-movement",
    "anti-detection",
    "claude",
    "agent"
  ],
  "license": "MIT",
  "author": "Deepanshu Kumar",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6"
  },
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
